{
  "manifest_version": 3,
  "name": "Snaps by T4H",
  "version": "1.0.0",
  "description": "Capture tabs instantly. Get T4H intelligence, widgets, and tools in your side panel.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabs",
    "contextMenus",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Snap this tab",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "quick-snap": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Snap current tab"
    },
    "dump-window": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Dump all tabs in window"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}